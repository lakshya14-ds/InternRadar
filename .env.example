# ==========================================
# InternRadar Unified Environment Template
# ==========================================

# 📐 Frontend Environment Variables (Vercel)
# ------------------------------------------
# Production Backend URL (Railway FastAPI URL)
NEXT_PUBLIC_API_URL=https://internradar-production.up.railway.app

# NextAuth Configuration
NEXTAUTH_URL=https://intern-radar-tau.vercel.app
NEXTAUTH_SECRET=internradar-secret-dev

# Google OAuth Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


# 🛠️ Backend Environment Variables (Railway)
# ------------------------------------------
# Main deployment URL of the API (or fallback proxy URL)
BACKEND_URL=https://internradar-production.up.railway.app

# Database Configuration
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/dbname
DB_NAME=internradar

# Security Configuration
JWT_SECRET=super-secret-key

# Scraper Orchestration
SCRAPER_INTERVAL_MINUTES=30

# Telegram Bot Notifications
BOT_TOKEN=
CHAT_ID=

# Redis Cache / Message Broker (if used)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# SMTP / Email Notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=

# Discord Webhook Notifications
DISCORD_WEBHOOK_URL=

# Twilio SMS / Whatsapp API
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
TWILIO_WHATSAPP_TO=

# JSearch API Key / RapidAPI
RAPIDAPI_KEY=
